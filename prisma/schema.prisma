// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserStatus {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?
  isActive    Boolean @default(true)
  metadata    Json?
  order       Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users User[]

  @@index([name])
  @@index([code])
  @@index([isActive])
  @@index([deletedAt])
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique @db.VarChar(255)
  firstName           String      @db.VarChar(100)
  lastName            String      @db.VarChar(100)
  userStatusId        String?
  userStatus          UserStatus? @relation(fields: [userStatusId], references: [id], onUpdate: Cascade, onDelete: SetNull, map: "user_status_fk")
  tenantId            String?
  tenant              Tenant?     @relation(fields: [tenantId], references: [id], onUpdate: Cascade, onDelete: SetNull)
  failedLoginAttempts Int         @default(0) @map("failed_login_attempts")
  lastFailedLoginAt   DateTime?
  lockedAt            DateTime?
  lockReason          String?     @db.Text
  lockCount           Int         @default(0)
  autoUnlockAt        DateTime?
  lastLoginAt         DateTime?
  metadata            Json?
  version             Int         @default(1)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userRoles        UserRole[]
  sessions         Session[]
  password         Password?
  recoveryCodes    RecoveryCode[]
  passwordHistory  PasswordHistory[]
  invitationsSent  Invitation[]
  notifications    Notification[]
  ssoConnections   SSOConnection[]
  notesAuthored    Note[]            @relation("NoteAuthor")
  noteComments     NoteComment[]
  submittedChanges ChangeRequest[]   @relation("ChangeSubmitter")
  reviewedChanges  ChangeRequest[]   @relation("ChangeReviewer")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email, deletedAt])
  @@index([userStatusId])
  @@index([deletedAt])
  @@index([email])
  @@index([lastLoginAt])
}

model Password {
  id     String @id @default(cuid())
  hash   String @db.VarChar(255)
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  lastChanged DateTime  @default(now())
  version     Int       @default(1)

  @@index([hash])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  expiresAt DateTime
  metadata  Json?
  version   Int      @default(1)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model Verification {
  id        String    @id @default(cuid())
  type      String    @db.VarChar(50)
  target    String    @db.VarChar(255)
  secret    String    @db.VarChar(255)
  algorithm String    @db.VarChar(50)
  digits    Int
  period    Int
  charSet   String    @db.VarChar(255)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([target, type])
  @@index([type])
  @@index([expiresAt])
  @@index([deletedAt])
}

model Role {
  id          String    @id @default(cuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  scope       RoleScope @default(TENANT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(cuid())
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(100)
  module      String   @default("system") @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action], name: "resource_action")
  @@index([module])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String
  access       String @default("any") // "own" | "any"

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id      String  @id @default(cuid())
  userId  String
  roleId  String
  eventId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, eventId])
  @@index([userId])
  @@index([roleId])
}

enum RoleScope {
  GLOBAL
  TENANT
  EVENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
  SUSPENDED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
  DEAD_LETTER
}

model Tenant {
  id               String  @id @default(cuid())
  name             String  @unique @db.VarChar(255)
  slug             String  @unique @db.VarChar(120)
  email            String  @unique @db.VarChar(255)
  phone            String  @db.VarChar(50)
  city             String  @db.VarChar(100)
  state            String  @db.VarChar(100)
  address          String  @db.Text
  logoUrl          String? @db.VarChar(500)
  brandTheme       String  @default("") @db.VarChar(50)
  subscriptionPlan String  @default("free") @db.VarChar(50)

  metadata Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users                User[]
  roles                Role[]
  invitations          Invitation[]
  systemSettings       SystemSetting[]
  notifications        Notification[]
  webhookSubscriptions WebhookSubscription[]
  countries            Country[]
  titles               Title[]
  languages            Language[]
  currencies           Currency[]
  ssoConfigurations    SSOConfiguration[]
  ssoConnections       SSOConnection[]
  notes                Note[]
  noteCategories       NoteCategory[]
  organizations        Organization[]
  organizationTypes    OrganizationType[]
  people               Person[]
  positions            Position[]
  positionTypes        PositionType[]
  positionAssignments  PositionAssignment[]
  memberStates         MemberState[]
  regionalGroups       RegionalGroup[]
  changeRequests       ChangeRequest[]

  @@index([name])
  @@index([slug])
  @@index([email])
  @@index([deletedAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  tenantId       String?
  userId         String?
  actingAsUserId String?
  action         String   @db.VarChar(100)
  entityType     String   @db.VarChar(100)
  entityId       String?  @db.VarChar(255)
  description    String?  @db.Text
  metadata       Json?
  ipAddress      String?  @db.VarChar(64)
  userAgent      String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([tenantId, action, createdAt])
  @@index([entityType, entityId])
}

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @db.VarChar(255)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordHistory {
  id        String   @id @default(cuid())
  userId    String
  hash      String   @db.VarChar(255)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Invitation {
  id          String           @id @default(cuid())
  email       String           @db.VarChar(255)
  tenantId    String
  roleIds     String[]
  token       String           @unique @db.VarChar(128)
  status      InvitationStatus @default(PENDING)
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime         @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation(fields: [invitedById], references: [id])

  @@index([token])
  @@index([tenantId])
  @@index([email])
  @@index([status])
}

model SystemSetting {
  id             String    @id @default(cuid())
  tenantId       String?
  key            String    @db.VarChar(120)
  value          String    @db.Text
  type           String    @default("string") @db.VarChar(20)
  category       String    @default("general") @db.VarChar(50)
  scope          String    @default("global") @db.VarChar(20)
  scopeId        String    @default("") @db.VarChar(120)
  lastAccessedAt DateTime?
  accessCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([key, scope, scopeId])
  @@index([tenantId])
  @@index([category])
}

model FeatureFlag {
  id                 String   @id @default(cuid())
  key                String   @unique @db.VarChar(120)
  description        String?  @db.Text
  scope              String   @default("tenant") @db.VarChar(20)
  enabled            Boolean  @default(false)
  enabledForTenants  String[] @default([])
  disabledForTenants String[] @default([])
  enabledForRoles    String[] @default([])
  enabledForUsers    String[] @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Events & Jobs ─────────────────────────────────────

model Job {
  id          String    @id @default(cuid())
  type        String    @db.VarChar(100)
  payload     Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  nextRunAt   DateTime  @default(now())
  lastError   String?   @db.Text
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([status, nextRunAt])
  @@index([type])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String   @db.VarChar(255)
  tenantId     String
  method       String   @db.VarChar(10)
  path         String   @db.VarChar(500)
  statusCode   Int
  responseBody String   @db.Text
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([key, tenantId])
  @@index([expiresAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  tenantId  String
  type      String    @db.VarChar(100)
  title     String    @db.VarChar(255)
  message   String    @db.Text
  data      Json?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model WebhookSubscription {
  id                    String        @id @default(cuid())
  tenantId              String
  url                   String        @db.VarChar(500)
  description           String?       @db.Text
  events                String[]
  secret                String        @db.VarChar(255)
  status                WebhookStatus @default(ACTIVE)
  version               String        @default("v1") @db.VarChar(10)
  maxRetries            Int           @default(5)
  retryBackoffMs        Int[]         @default([1000, 5000, 30000, 300000, 1800000])
  timeoutMs             Int           @default(10000)
  consecutiveFailures   Int           @default(0)
  circuitBreakerOpen    Boolean       @default(false)
  circuitBreakerResetAt DateTime?
  headers               Json?
  metadata              Json?
  createdBy             String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId, status])
}

model WebhookDelivery {
  id              String         @id @default(cuid())
  tenantId        String
  subscriptionId  String
  eventType       String         @db.VarChar(100)
  eventId         String         @db.VarChar(255)
  payload         Json
  status          DeliveryStatus @default(PENDING)
  attempts        Int            @default(0)
  maxAttempts     Int            @default(5)
  nextRetryAt     DateTime?
  responseCode    Int?
  responseBody    String?        @db.Text
  responseHeaders Json?
  latencyMs       Int?
  errorMessage    String?        @db.Text
  errorType       String?        @db.VarChar(100)
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
  @@index([tenantId, eventType, createdAt])
  @@index([status, nextRetryAt])
  @@index([eventId])
  @@index([createdAt])
}

// ─── Reference Data ────────────────────────────────────

model Country {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   @db.VarChar(2)
  name        String   @db.VarChar(100)
  alpha3      String?  @db.VarChar(3)
  numericCode String?  @db.VarChar(3)
  phoneCode   String?  @db.VarChar(10)
  flag        String?  @db.VarChar(10)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive, sortOrder])
}

model Title {
  id        String   @id @default(cuid())
  tenantId  String
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive, sortOrder])
}

model Language {
  id         String   @id @default(cuid())
  tenantId   String
  code       String   @db.VarChar(10)
  name       String   @db.VarChar(100)
  nativeName String?  @db.VarChar(100)
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive, sortOrder])
}

model Currency {
  id            String   @id @default(cuid())
  tenantId      String
  code          String   @db.VarChar(3)
  name          String   @db.VarChar(100)
  symbol        String?  @db.VarChar(10)
  decimalDigits Int      @default(2)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive, sortOrder])
}

// ─── SSO ─────────────────────────────────────────────

enum SSOProvider {
  OKTA
  AZURE_AD
  GOOGLE
  CUSTOM_OIDC
  CUSTOM_SAML
}

enum SSOProtocol {
  OIDC
  SAML
}

model SSOConfiguration {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        SSOProvider
  protocol        SSOProtocol @default(OIDC)
  displayName     String?     @db.VarChar(200)
  issuerUrl       String?     @db.VarChar(500)
  clientId        String?     @db.VarChar(255)
  clientSecret    String?     @db.Text
  metadataUrl     String?     @db.VarChar(500)
  callbackUrl     String      @db.VarChar(500)
  autoProvision   Boolean     @default(false)
  enforceSSO      Boolean     @default(false)
  defaultRoleId   String?
  x509Certificate String?     @db.Text
  ssoUrl          String?     @db.VarChar(500)
  spEntityId      String?     @db.VarChar(500)
  nameIdFormat    String?     @default("urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress") @db.VarChar(255)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId])
}

model SSOConnection {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       SSOProvider
  providerUserId String      @db.VarChar(255)
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email          String      @db.VarChar(255)
  displayName    String?     @db.VarChar(200)
  avatarUrl      String?     @db.VarChar(500)
  lastLoginAt    DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([provider, providerUserId])
  @@unique([userId, provider, tenantId])
  @@index([userId])
  @@index([tenantId])
}

// ─── Notes (demo entity) ─────────────────────────────
// The Notes module is the template's "living documentation" — it exercises
// every shipped pattern (shared editor, cascading selects, saved views, custom
// fields, dialog sub-entities, soft delete, versioning) so apps forked from
// the template have a working reference to copy from.

enum NoteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model NoteCategory {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String         @db.VarChar(100)
  color       String?        @db.VarChar(20)
  parentId    String?
  parent      NoteCategory?  @relation("NoteCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    NoteCategory[] @relation("NoteCategoryTree")
  sortOrder   Int            @default(0)
  description String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  notes Note[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
}

model Note {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String        @db.VarChar(255)
  content    String        @db.Text
  status     NoteStatus    @default(DRAFT)
  categoryId String?
  category   NoteCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags       String[]
  dueDate    DateTime?
  authorId   String
  author     User          @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  version    Int           @default(1)
  metadata   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?

  comments NoteComment[]

  @@index([tenantId])
  @@index([tenantId, status, deletedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([deletedAt])
}

model NoteComment {
  id        String    @id @default(cuid())
  noteId    String
  note      Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([noteId, createdAt])
  @@index([authorId])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// Directory subsystem — Organizations, People, Positions, Assignments
// + editorial workflow (ChangeRequest). See
// docs/plans/2026-04-21-organizations-people-directory.md.
// ─────────────────────────────────────────────────────────────────────────

model RegionalGroup {
  id          String  @id @default(cuid())
  tenantId    String
  code        String  @db.VarChar(20)
  name        String  @db.VarChar(100)
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members MemberStateRegion[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
}

model MemberState {
  id             String   @id @default(cuid())
  tenantId       String
  fullName       String   @db.VarChar(255)
  abbreviation   String   @db.VarChar(20)
  dateJoined     DateTime @db.Date
  isActive       Boolean  @default(true)
  predecessorOrg String?  @db.VarChar(10) // OAU | AU
  notes          String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  regions MemberStateRegion[]
  people  Person[]

  @@unique([tenantId, abbreviation])
  @@index([tenantId])
  @@index([fullName])
  @@index([deletedAt])
}

model MemberStateRegion {
  id              String @id @default(cuid())
  memberStateId   String
  regionalGroupId String

  createdAt DateTime @default(now())

  memberState   MemberState   @relation(fields: [memberStateId], references: [id], onDelete: Cascade)
  regionalGroup RegionalGroup @relation(fields: [regionalGroupId], references: [id], onDelete: Cascade)

  @@unique([memberStateId, regionalGroupId])
  @@index([regionalGroupId])
}

model OrganizationType {
  id          String  @id @default(cuid())
  tenantId    String
  name        String  @db.VarChar(100)
  code        String  @db.VarChar(50)
  level       Int
  description String?
  sortOrder   Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizations Organization[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
}

model Organization {
  id                String    @id @default(cuid())
  tenantId          String
  name              String    @db.VarChar(255)
  acronym           String?   @db.VarChar(50)
  typeId            String
  parentId          String?
  description       String?   @db.Text
  mandate           String?   @db.Text
  establishmentDate DateTime? @db.Date
  isActive          Boolean   @default(true)
  website           String?   @db.VarChar(255)
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(50)
  address           String?   @db.Text
  sortOrder         Int       @default(0)
  version           Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      OrganizationType @relation(fields: [typeId], references: [id])
  parent    Organization?    @relation("OrgTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Organization[]   @relation("OrgTree")
  positions Position[]

  @@index([tenantId])
  @@index([tenantId, parentId])
  @@index([tenantId, typeId])
  @@index([name])
  @@index([acronym])
  @@index([deletedAt])
}

model Person {
  id            String   @id @default(cuid())
  tenantId      String
  firstName     String   @db.VarChar(100)
  lastName      String   @db.VarChar(100)
  honorific     String?  @db.VarChar(50)
  email         String?  @db.VarChar(255)
  phone         String?  @db.VarChar(50)
  bio           String?  @db.Text
  photoUrl      String?  @db.VarChar(500)
  memberStateId String?
  languages     String[]

  // Contact-visibility opt-ins — public helpers only surface these when true.
  showEmail Boolean @default(false)
  showPhone Boolean @default(false)

  version Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberState MemberState?         @relation(fields: [memberStateId], references: [id])
  assignments PositionAssignment[]

  @@index([tenantId])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, memberStateId])
  @@index([email])
  @@index([deletedAt])
}

model PositionType {
  id             String  @id @default(cuid())
  tenantId       String
  name           String  @db.VarChar(100)
  code           String  @db.VarChar(50)
  description    String?
  hierarchyLevel Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  positions Position[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
}

model Position {
  id             String  @id @default(cuid())
  tenantId       String
  organizationId String
  typeId         String
  title          String  @db.VarChar(255)
  reportsToId    String?
  description    String? @db.Text
  isActive       Boolean @default(true)
  sortOrder      Int     @default(0)
  version        Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type         PositionType         @relation(fields: [typeId], references: [id])
  reportsTo    Position?            @relation("PositionReports", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports      Position[]           @relation("PositionReports")
  assignments  PositionAssignment[]

  @@index([tenantId])
  @@index([tenantId, organizationId])
  @@index([tenantId, typeId])
  @@index([deletedAt])
}

model PositionAssignment {
  id         String    @id @default(cuid())
  tenantId   String
  positionId String
  personId   String
  startDate  DateTime  @db.Date
  endDate    DateTime? @db.Date
  isCurrent  Boolean   @default(true)
  notes      String?
  version    Int       @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  person   Person   @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, positionId, isCurrent])
  @@index([tenantId, personId])
  @@index([tenantId, startDate])
  @@index([deletedAt])
}

// ─── Editorial workflow ──────────────────────────────────────────────────

enum ChangeOperation {
  CREATE
  UPDATE
  DELETE
  MOVE
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ApprovalMode {
  REVIEWED
  SELF_APPROVED
}

enum DirectoryEntity {
  ORGANIZATION
  PERSON
  POSITION
  POSITION_ASSIGNMENT
}

model ChangeRequest {
  id            String          @id @default(cuid())
  tenantId      String
  entityType    DirectoryEntity
  entityId      String?
  operation     ChangeOperation
  payload       Json
  status        ChangeStatus    @default(PENDING)
  approvalMode  ApprovalMode    @default(REVIEWED)
  submittedById String
  submittedAt   DateTime        @default(now())
  reviewedById  String?
  reviewedAt    DateTime?
  reviewerNotes String?         @db.Text
  appliedAt     DateTime?
  failureReason String?         @db.Text
  clonedFromId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedBy User            @relation("ChangeSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User?           @relation("ChangeReviewer", fields: [reviewedById], references: [id])
  clonedFrom  ChangeRequest?  @relation("ChangeClone", fields: [clonedFromId], references: [id], onDelete: SetNull)
  clones      ChangeRequest[] @relation("ChangeClone")

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, submittedById])
  @@index([tenantId, status, submittedAt])
  @@index([tenantId, status, reviewedAt])
}
