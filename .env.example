# ─── Required ─────────────────────────────────────────

# Runtime
NODE_ENV=development

# Database (matches docker-compose defaults)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
DB_PORT=5432
DB_TEST_NAME=app_test
DB_TEST_PORT=5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app?schema=public"
DATABASE_TEST_URL="postgresql://postgres:postgres@localhost:5433/app_test?schema=public"

# Auth — MUST change in production
SESSION_SECRET=change-me-in-production
HONEYPOT_SECRET=change-me-in-production

# Email (dev uses MSW mocks — see tests/mocks/handlers.ts)
RESEND_API_KEY=dev-key

# ─── Optional ─────────────────────────────────────────

# HTTP port for the Express server. Defaults to 3000.
PORT=3000

# Public-facing URL — used for OAuth / SAML callbacks + email links.
# Defaults to http://localhost:5173 when unset.
APP_URL=http://localhost:5173

# Service metadata — exposed via logs + Sentry tags.
APP_NAME=app
APP_VERSION=dev

# Logger level (fatal | error | warn | info | debug | trace). Defaults to info.
LOG_LEVEL=info

# Sentry — leave empty to disable error tracking.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate limiting — override the general limiter's window + max requests.
# Defaults: 900000ms (15 min) / 300 requests.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# CORS — comma-separated origin allowlist. Defaults to http://localhost:3000.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Testing — MSW handlers auto-start in dev (NODE_ENV=development).
# Set TESTING=true to disable the honeypot field-timing check in automated tests.
# E2E_PORT (default 3001) and E2E_BASE_URL override Playwright's dev-server target.

# ─── Legacy (carried over from pre-template impl) ─────
#
# Microsoft Entra ID / Graph credentials used by the legacy Greenbook auth +
# org-chart sync. The current template does NOT consume these directly —
# SSO is configured per-tenant via the SSOConfiguration DB model (OIDC / SAML).
# Keep these set in prod until MS auth is re-wired into the template's SSO
# admin UI (/settings/security/sso) or until you confirm they're unused.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=
